<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ dictionary.title }}</title>
<style>{{ css | safe }}</style>
</head>
<body id="top">
<div class="container">
  <h1 class="title">{{ dictionary.title }}</h1>

  {% if dictionary.sections | length > 1 %}
  <nav class="toc">
    <h2 class="toc__title">Sections</h2>
    <ul class="toc__list">
    {% for entry in toc_entries %}
      <li class="toc__item toc__item--depth-{{ entry.depth }}"><a href="#section-{{ entry.index }}">{% if entry.parent %}<span class="toc__parent">{{ entry.parent }} › </span>{% endif %}{{ entry.name or "(no section)" }}</a><span class="toc__count">{{ entry.count }}</span></li>
    {% endfor %}
    </ul>
  </nav>
  {% endif %}

  {% for section in dictionary.sections %}
  <section class="section" id="section-{{ loop.index }}">
    <h2 class="section__name">{{ section.name }}<span class="section__count">{{ section.records | length }} data element{{ "s" if section.records | length != 1 }}</span></h2>

    {% for record in section.records %}
    <article class="record" id="{{ record.id }}">
      <table class="record__table">
        <tbody>
          <tr>
            <th class="record__number">{{ record.number }})</th>
            <td><span class="badge record__id">{{ record.id }}</span> <a class="record__anchor" href="#{{ record.id }}" title="Link to this data element">&para;</a></td>
          </tr>
          <tr><th>Label</th><td><strong class="record__label">{{ record.label }}</strong></td></tr>
          {% if record.datatype %}
          <tr><th>Datatype</th><td><span class="badge record__facet">{{ record.datatype }}</span></td></tr>
          {% endif %}
          {% if record.cardinality %}
          <tr><th>Cardinality</th><td><span class="badge record__facet">{{ record.cardinality }}</span></td></tr>
          {% endif %}
          {% if record.unit %}
          <tr><th>Unit</th><td><span class="badge record__facet">{{ record.unit }}</span></td></tr>
          {% endif %}
          {% if record.pattern %}
          <tr><th>Pattern</th><td><code>{{ record.pattern }}</code></td></tr>
          {% endif %}
          {% if record.required %}
          <tr><th>Required</th><td><span class="badge record__required">required</span></td></tr>
          {% endif %}
          {% if record.precondition %}
          <tr><th>Precondition</th><td>{{ record.precondition_html | safe }}</td></tr>
          {% endif %}
          {% if record.terms %}
          <tr><th>Terms</th><td>
            {% for term in record.terms %}<div class="term__row"><span class="badge term">{{ term }}</span>{% if term_labels.get(term) %} <span class="term__label">{{ term_labels[term] }}</span>{% endif %}</div>{% endfor %}
          </td></tr>
          {% endif %}
          {% if record.description_html %}
          <tr><th>Description</th><td class="record__description">{{ record.description_html | safe }}</td></tr>
          {% endif %}
          {% if record.choices %}
          <tr><th>Enumeration</th><td>
            <table class="enumeration">
              <tbody>
              {% for choice in record.choices %}
                <tr>
                  <td><span class="badge choice__value{% if choice.is_missing_value_code %} choice__value--missing-value-code{% endif %}">{{ choice.value }}</span></td>
                  <td class="choice__label">{{ choice.label }}</td>
                  {% if choice.meaning %}<td><span class="badge term">{{ choice.meaning }}</span>{% if term_labels.get(choice.meaning) %} <span class="term__label">{{ term_labels[choice.meaning] }}</span>{% endif %}</td>{% endif %}
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </td></tr>
          {% endif %}
          {% if record.notes_html %}
          <tr><th>Notes</th><td class="record__notes">{{ record.notes_html | safe }}</td></tr>
          {% endif %}
        </tbody>
      </table>
    </article>
    {% endfor %}
  </section>
  {% endfor %}
</div>
<a class="back-to-top" href="#top" title="Back to top">&uarr;</a>
</body>
</html>
